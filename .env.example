# Copy this file to `.env` and fill in your values. Vite only exposes vars
# prefixed with VITE_ to the client.

# Enable ads: "1" or "true". Leave empty/0 for ad-free development.
VITE_ADS=0

# AdSense client / publisher ID (from your AdSense account), e.g. ca-pub-1234567890123456
VITE_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX

# Display ad unit slot IDs (the data-ad-slot numbers from each ad unit).
VITE_ADSENSE_SLOT_HEADER=0000000000
VITE_ADSENSE_SLOT_SIDEBAR=0000000000
VITE_ADSENSE_SLOT_GRID=0000000000
